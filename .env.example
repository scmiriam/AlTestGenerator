# ── Copia este fichero a .env y rellena tus valores ───────────────────
# cp .env.example .env

# ── LLM providers (define al menos uno) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# Para Ollama no hace falta API key; asegúrate de que el servidor esté corriendo

# ── Proyecto AL de Business Central ──────────────────────────────────
# Ruta al workspace con las carpetas guarantees/ y guarantees-test/
# Si no se define, el agente usa la ruta hardcodeada en ProjectConfig.default()
PROJECT_ROOT=C:\Users\mscarafu\Downloads\GarantiasAAPP

# ── Modelos de embedding ──────────────────────────────────────────────
# TRANSFORMERS_OFFLINE=1  # descomenta si el modelo ya está cacheado

# ── ChromaDB ─────────────────────────────────────────────────────────
